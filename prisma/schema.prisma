datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  WAITER
  CASHIER
  KITCHEN_STAFF
  RECEPTIONIST
}

model User {
  id            String    @id @default(uuid())
  name          String
  phoneNumber   String    @unique
  passwordHash  String
  role          Role      @default(WAITER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens RefreshToken[]
  Order         Order[]

  @@index([phoneNumber])
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuItems MenuItem[]
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Order {
  id Int @id @default(autoincrement())

  phoneNumber String @db.VarChar(15)
  tableNumber Int?
  items       Json
  kotHistory  Json @default("[]")

  baseAmount Decimal @db.Decimal(10, 2) @default(0)
  gstAmount Decimal @db.Decimal(10, 2) @default(0)
  discountAmount Decimal @db.Decimal(10, 2) @default(0)
  finalDiscountedAmount Decimal @db.Decimal(10, 2) @default(0)

  cancellationReason String?

  status OrderStatus @default(PENDING)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phoneNumber])
  @@index([status, createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model RoomType {
  id             Int      @id @default(autoincrement())
  name           String
  roomCode       String   @unique
  description    String?
  maxAdults      Int
  maxChildren    Int
  totalRooms     Int
  basePrice          Decimal?     @db.Decimal(10,2)
  extraPersonAmount  Decimal?     @default(0) @db.Decimal(10,2)
  rateplanCodes      Json?        
  rooms              Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
}

enum BookingStatus {
  RESERVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum BookingSource {
  DIRECT
  OTA
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

model UserRoomBooking {
  id                 Int            @id @default(autoincrement())

  bookingId          String

  source             BookingSource
  channel            String?

  guestName          String?

  guestEmail         String?
  guestPhone         String
  guestAddress       Json?

  checkIn            DateTime
  checkOut           DateTime

  rooms              Json           @default("[]")

  totalAmount        Decimal        @db.Decimal(10,2)
  taxAmount          Decimal        @default(0) @db.Decimal(10,2)
  commission         Decimal?       @db.Decimal(10,2)

  paymentStatus      PaymentStatus
  payAtHotel         Boolean

  status             BookingStatus

  specialRequests    String?

  bookedOn           DateTime

  webhookPayload     Json?

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([channel, bookingId])
  @@index([status])
  @@index([guestPhone])
  @@index([source])
  @@index([checkIn, checkOut])
}